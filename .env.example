# Скопируйте в .env и настройте под окружение (docker compose подхватывает автоматически)

# PostgreSQL
POSTGRES_PASSWORD=ChangeMe_StrongPassword_123!
POSTGRES_PORT=5433

# Порты сервисов на хосте
BACKEND_PORT=5025
FRONTEND_PORT=5173

# Backend
ASPNETCORE_ENVIRONMENT=Development
DATABASE_AUTO_MIGRATE=true
AUTH_ENABLED=false

# OpenTelemetry (опционально; при docker compose -f docker-compose.monitoring.yml up -d)
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317

# Локальная разработка frontend (npm run dev)
VITE_API_PROXY_TARGET=http://localhost:5025

# Опционально: включить auth skeleton (синхронно с AUTH_ENABLED на backend)
# VITE_AUTH_ENABLED=true
